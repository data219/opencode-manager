// opencode-docker-config:1
// Dual-provider: Z.AI Coding Plan Pro (glm) + Google AI Studio Free (gemini)
// Tiers: glm-5.1 (Opus-level, max quality), glm-5-turbo (Opus-level, fast), glm-4.7 (Sonnet-level), gemini-2.5-flash (offload)
// Strategy: Premium agents on Z.AI, cheap/high-volume agents on Google to preserve Z.AI slots
{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    // === Z.AI Premium (Opus-level) ===
    "sisyphus": {
      "model": "zai-coding-plan/glm-5.1",
      "fallback_models": [
        "zai-coding-plan/glm-5-turbo",
        "zai-coding-plan/glm-4.7"
      ]
    },
    "hephaestus": {
      "model": "zai-coding-plan/glm-5-turbo",
      "fallback_models": [
        "zai-coding-plan/glm-4.7"
      ],
      "prompt_append": "Follow established plans precisely. Ask for clarification when plans are ambiguous. Prefer small, testable changes. Use LSP and AST-grep aggressively."
    },
    "prometheus": {
      "model": "zai-coding-plan/glm-5.1",
      "fallback_models": [
        "zai-coding-plan/glm-5-turbo",
        "zai-coding-plan/glm-4.7"
      ],
      "prompt_append": "Always interview first. Validate scope before planning. Build exhaustive plans with milestones, risks, and contingencies. Max 2 parallel background tasks."
    },
    "metis": {
      "model": "zai-coding-plan/glm-5.1",
      "fallback_models": [
        "zai-coding-plan/glm-5-turbo"
      ],
      "prompt_append": "Critically evaluate plans. Identify gaps, risks, and improvements. Be thorough."
    },
    "oracle": {
      "model": "zai-coding-plan/glm-5.1",
      "fallback_models": [
        "zai-coding-plan/glm-5-turbo"
      ]
    },
    "momus": {
      "model": "zai-coding-plan/glm-5.1",
      "prompt_append": "Challenge all assumptions in plans. Look for edge cases, failure modes, and overlooked requirements."
    },
    // === Z.AI Mid-tier ===
    "atlas": {
      "model": "zai-coding-plan/glm-4.7"
    },
    "sisyphus-junior": {
      "model": "zai-coding-plan/glm-5-turbo",
      "fallback_models": [
        "zai-coding-plan/glm-4.7"
      ]
    },
    // === Google AI Studio (offload high-volume agents) ===
    "explore": {
      "model": "google-aistudio/gemini-2.5-flash",
      "fallback_models": [
        "zai-coding-plan/glm-4.5-air"
      ],
      "prompt_append": "Prefer searching official documentation and library sources over general web search."
    },
    "librarian": {
      "model": "google-aistudio/gemini-2.5-flash",
      "fallback_models": [
        "zai-coding-plan/glm-4.5-air"
      ],
      "prompt_append": "Focus on finding authoritative sources. Cross-reference results when possible."
    },
    "multimodal-looker": {
      "model": "google-aistudio/gemini-2.5-flash",
      "fallback_models": [
        "zai-coding-plan/glm-4.7"
      ]
    }
  },
  "categories": {
    // === Z.AI Premium ===
    "ultrabrain": {
      "model": "zai-coding-plan/glm-5.1"
    },
    "visual-engineering": {
      "model": "google-aistudio/gemini-2.5-flash",
      "fallback_models": [
        "zai-coding-plan/glm-4.7"
      ]
    },
    "unspecified-high": {
      "model": "zai-coding-plan/glm-5.1"
    },
    // === Z.AI Fast ===
    "deep": {
      "model": "zai-coding-plan/glm-5-turbo"
    },
    // === Z.AI Mid-tier ===
    "writing": {
      "model": "zai-coding-plan/glm-4.7"
    },
    // === Google AI Studio (offload high-volume categories) ===
    "quick": {
      "model": "google-aistudio/gemini-2.5-flash"
    },
    "unspecified-low": {
      "model": "google-aistudio/gemini-2.5-flash"
    },
    "artistry": {
      "model": "google-aistudio/gemini-2.5-flash",
      "fallback_models": [
        "zai-coding-plan/glm-4.7"
      ]
    }
  },
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [
      429,
      503,
      529
    ],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60
  },
  "background_task": {
    "providerConcurrency": {
      "zai-coding-plan": 3,
      "google-aistudio": 3
    },
    "modelConcurrency": {
      "zai-coding-plan/glm-5.1": 2,
      "zai-coding-plan/glm-5-turbo": 2,
      "zai-coding-plan/glm-4.7": 2,
      "zai-coding-plan/glm-4.5-air": 1,
      "google-aistudio/gemini-2.5-flash": 3
    }
  },
  "browser_automation_engine": {
    "provider": "agent-browser"
  },
  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": true,
    "git_env_prefix": "GIT_"
  },
  "sisyphus_agent": {
    "planner_enabled": true,
    "replace_plan": true
  },
  // Enable all coding aids
  "hashline_edit": true,
  "experimental": {
    "aggressive_truncation": false,
    "task_system": true,
    "auto_resume": true
  }
}
